# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/fifthcusp

# JWT
JWT_ACCESS_SECRET=your_access_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_here_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000,https://fifthcusp.com

# Mail (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@fifthcusp.com

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Google Calendar (Service Account)
# Create two calendars in Google Calendar, share them with the service account email
# with "Make changes to events" permission, and paste their IDs below.
# Wrap GOOGLE_PRIVATE_KEY in double quotes to preserve newlines.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_CONSULTATION_CALENDAR_ID=your_consultation_calendar_id@group.calendar.google.com
GOOGLE_REMEDY_CALENDAR_ID=your_remedy_calendar_id@group.calendar.google.com
# Workspace mode — set true in production (Google Workspace + Domain-Wide Delegation)
# to auto-generate a unique Meet link per booking and invite the client as attendee.
# Leave false on a consumer Gmail account (dev).
GOOGLE_WORKSPACE_MODE=false
# Workspace user to impersonate via Domain-Wide Delegation (production only)
GOOGLE_IMPERSONATE_EMAIL=
# Fallback meeting link used when GOOGLE_WORKSPACE_MODE=false (e.g. a permanent
# Google Meet room: https://meet.google.com/abc-defg-hij — or a Zoom link)
CONSULTATION_FALLBACK_MEET_LINK=

# Order file storage
UPLOAD_DIR=uploads
ORDER_FILES_RETENTION_DAYS=7
MAX_ORDER_UPLOAD_MB=50
