{
  "info": {
    "name": "FifthCusp â€” Careers API",
    "_postman_id": "fifthcusp-careers-v1",
    "description": "CRUD endpoints for the Job Openings collection. Set the `baseUrl` and `adminToken` collection variables before running.\n\n**baseUrl** â€” e.g. `http://localhost:5000`\n**adminToken** â€” Bearer token from POST /api/v1/auth/login (admin role required for write operations)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string",
      "description": "Paste your admin JWT access token here"
    },
    {
      "key": "jobId",
      "value": "",
      "type": "string",
      "description": "Auto-populated by the Create Job Opening request"
    }
  ],
  "item": [
    {
      "name": "Careers",
      "item": [
        {
          "name": "List All Job Openings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/careers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "careers"]
            },
            "description": "Returns all job openings sorted by newest first. No auth required.\n\nOptional query params:\n- `isActive=true` â€” only active listings\n- `isClosed=true` â€” only closed listings\n- `department=Astrology` â€” filter by department (case-insensitive)"
          },
          "response": []
        },
        {
          "name": "List Active Job Openings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/careers?isActive=true&isClosed=false",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "careers"],
              "query": [
                { "key": "isActive", "value": "true" },
                { "key": "isClosed", "value": "false" }
              ]
            },
            "description": "Returns only active, open job listings. Use this for the public careers page. No auth required."
          },
          "response": []
        },
        {
          "name": "List by Department â€“ Astrology",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/careers?department=Astrology",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "careers"],
              "query": [
                { "key": "department", "value": "Astrology" }
              ]
            },
            "description": "Filter job openings by department. Case-insensitive. No auth required."
          },
          "response": []
        },
        {
          "name": "Get Job Opening by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/careers/{{jobId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "careers", "{{jobId}}"]
            },
            "description": "Fetch a single job opening by its MongoDB ObjectId. No auth required."
          },
          "response": []
        },
        {
          "name": "Create Job Opening",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "  pm.collectionVariables.set('jobId', json.data.id);",
                  "  console.log('jobId set to', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Vedic Astrologer\",\n  \"description\": \"We are looking for an experienced Vedic Astrologer to provide personalised birth chart readings, transit analysis, and predictive consultations to our clients.\",\n  \"department\": \"Astrology\",\n  \"location\": \"Remote\",\n  \"employmentType\": \"full-time\",\n  \"experienceLevel\": \"senior\",\n  \"experienceYears\": 5,\n  \"skills\": [\"Vedic Astrology\", \"Kundli Reading\", \"Dasha Analysis\", \"Transit Forecasting\"],\n  \"qualifications\": [\n    \"Formal certification in Vedic Astrology\",\n    \"Strong command of Parashari and Jaimini systems\"\n  ],\n  \"responsibilities\": [\n    \"Conduct in-depth birth chart consultations via video or chat\",\n    \"Prepare written astrological reports for clients\",\n    \"Offer remedial guidance including gemstones, mantras, and rituals\"\n  ],\n  \"salaryMin\": 40000,\n  \"salaryMax\": 70000,\n  \"applicationDeadline\": \"2026-07-31T23:59:59.000Z\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/careers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "careers"]
            },
            "description": "Create a new job opening. Admin JWT required.\n\nThe test script auto-saves the new `id` into the `jobId` collection variable.\n\n`employmentType` options: `full-time`, `part-time`, `contract`, `freelance`\n`experienceLevel` options: `junior`, `mid`, `senior`"
          },
          "response": []
        },
        {
          "name": "Update Job Opening",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"salaryMin\": 45000,\n  \"salaryMax\": 75000,\n  \"applicationDeadline\": \"2026-08-31T23:59:59.000Z\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/careers/{{jobId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "careers", "{{jobId}}"]
            },
            "description": "Partial update â€” send only the fields you want to change. Admin JWT required."
          },
          "response": []
        },
        {
          "name": "Close Job Opening",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/careers/{{jobId}}/close",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "careers", "{{jobId}}", "close"]
            },
            "description": "Close a job opening (position filled or no longer accepting). Sets `isClosed: true`, `isActive: false`, and records `closedAt` timestamp. Admin JWT required."
          },
          "response": []
        },
        {
          "name": "Delete Job Opening",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/careers/{{jobId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "careers", "{{jobId}}"]
            },
            "description": "Permanently delete a job opening. Admin JWT required."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth (get token)",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.accessToken) {",
                  "  pm.collectionVariables.set('adminToken', json.data.accessToken);",
                  "  console.log('adminToken saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@fifthcusp.com\",\n  \"password\": \"yourpassword\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Login as admin. The test script automatically saves the `accessToken` into the `adminToken` collection variable so all subsequent admin requests are authenticated."
          },
          "response": []
        }
      ]
    }
  ]
}
