{
  "info": {
    "name": "FifthCusp — Services API",
    "_postman_id": "fifthcusp-services-v1",
    "description": "CRUD endpoints for the Services collection. Set the `baseUrl` and `adminToken` collection variables before running.\n\n**baseUrl** — e.g. `http://localhost:5000`\n**adminToken** — Bearer token from POST /api/v1/auth/login (admin role required for write operations)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string",
      "description": "Paste your admin JWT access token here"
    },
    {
      "key": "serviceId",
      "value": "",
      "type": "string",
      "description": "Auto-populated by the Create Service request"
    }
  ],
  "item": [
    {
      "name": "Services",
      "item": [
        {
          "name": "List All Services",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/services",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "services"]
            },
            "description": "Returns all services (active and inactive). No auth required."
          },
          "response": []
        },
        {
          "name": "List Active Services Only",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/services?active=true",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "services"],
              "query": [
                {
                  "key": "active",
                  "value": "true",
                  "description": "When true, returns only isActiveService=true records"
                }
              ]
            },
            "description": "Returns only active services. No auth required."
          },
          "response": []
        },
        {
          "name": "Get Service by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/services/{{serviceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "services", "{{serviceId}}"]
            },
            "description": "Fetch a single service by its MongoDB ObjectId. No auth required."
          },
          "response": []
        },
        {
          "name": "Create Service",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data._id) {",
                  "  pm.collectionVariables.set('serviceId', json.data._id);",
                  "  console.log('serviceId set to', json.data._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Tarot Card Reading\",\n  \"subtitle\": \"Guidance through the tarot\",\n  \"description\": \"A personalised tarot reading session covering your past, present, and future. Gain clarity on love, career, and life decisions through the ancient wisdom of tarot.\",\n  \"price\": 799,\n  \"isInSale\": true,\n  \"saleTitle\": \"Introductory Offer\",\n  \"hasSaleBanner\": true,\n  \"discountPercentage\": 15,\n  \"isActiveService\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/services",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "services"]
            },
            "description": "Create a new service. Admin JWT required.\n\nThe test script auto-saves the new `_id` into the `serviceId` collection variable."
          },
          "response": []
        },
        {
          "name": "Update Service",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 899,\n  \"isInSale\": true,\n  \"saleTitle\": \"Weekend Special\",\n  \"hasSaleBanner\": true,\n  \"discountPercentage\": 10\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/services/{{serviceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "services", "{{serviceId}}"]
            },
            "description": "Partial update — send only the fields you want to change. Admin JWT required."
          },
          "response": []
        },
        {
          "name": "Deactivate Service",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isActiveService\": false\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/services/{{serviceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "services", "{{serviceId}}"]
            },
            "description": "Soft-disable a service without deleting it. Admin JWT required."
          },
          "response": []
        },
        {
          "name": "Delete Service",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/services/{{serviceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "services", "{{serviceId}}"]
            },
            "description": "Permanently delete a service. Admin JWT required."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth (get token)",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.accessToken) {",
                  "  pm.collectionVariables.set('adminToken', json.data.accessToken);",
                  "  console.log('adminToken saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@fifthcusp.com\",\n  \"password\": \"yourpassword\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Login as admin. The test script automatically saves the `accessToken` into the `adminToken` collection variable so all subsequent admin requests are authenticated."
          },
          "response": []
        }
      ]
    }
  ]
}
